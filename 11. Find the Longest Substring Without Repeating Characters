import java.util.HashSet;
public class Main {
    public static void main(String[] args) {
        String s = "abcabcbb";
        int max = 0, i = 0, j = 0;
        HashSet<Character> set = new HashSet<>();
        while (j < s.length()) {
            if (!set.contains(s.charAt(j))) {
                set.add(s.charAt(j++));
                max = Math.max(max, set.size());
            } else {
                set.remove(s.charAt(i++));
            }
        }
        System.out.println(max);
    }
}
