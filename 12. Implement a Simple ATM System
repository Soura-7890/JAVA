class Account {
    int bal = 1000;
    void deposit(int amt) { bal += amt; }
    void withdraw(int amt) { bal -= amt; }
}
public class Main {
    public static void main(String[] args) {
        Account a = new Account();
        a.deposit(500);
        a.withdraw(200);
        System.out.println(a.bal);
    }
}
