import java.util.ArrayList;

class Student {
    int id; String name; int marks;
    Student(int i, String n, int m) { id = i; name = n; marks = m; }
    void display() {
        System.out.println(id + " " + name + " " + (marks > 40 ? "Pass" : "Fail"));
    }
}
public class Main {
    public static void main(String[] args) {
        ArrayList<Student> list = new ArrayList<>();
        list.add(new Student(1, "A", 50));
        list.add(new Student(2, "B", 30));
        for (Student s : list) s.display();
    }
}
