class CheckArgument extends Exception {}
public class Main {
    public static void main(String[] args) {
        try {
            if (args.length < 5) throw new CheckArgument();
            int sum = 0;
            for (int i = 0; i < 5; i++) sum += Integer.parseInt(args[i]);
            System.out.println(sum);
        } catch (CheckArgument e) {
            System.out.println("Argument < 5");
        }
    }
}
