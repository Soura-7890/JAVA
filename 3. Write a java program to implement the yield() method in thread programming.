class MyThread extends Thread {
    public void run() {
        for (int i = 0; i < 5; i++) {
            Thread.yield();
            System.out.println(Thread.currentThread().getName() + " " + i);
        }
    }
}
public class Main {
    public static void main(String[] args) {
        new MyThread().start();
        new MyThread().start();
    }
}
