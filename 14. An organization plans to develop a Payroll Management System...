class Emp {
    int id; String name; double basic;
    Emp(int i, String n, double b) { id = i; name = n; basic = b; }
}
class Manager extends Emp {
    Manager(int i, String n, double b) { super(i, n, b); }
    void salary() { System.out.println(basic + 5000); }
}
class Clerk extends Emp {
    Clerk(int i, String n, double b) { super(i, n, b); }
    void salary() { System.out.println(basic + 2000); }
}
public class Main {
    public static void main(String[] args) {
        new Manager(1, "A", 50000).salary();
        new Clerk(2, "B", 20000).salary();
    }
}
