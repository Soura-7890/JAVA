class Shared {
    synchronized void print() {
        for(int i=0;i<3;i++) System.out.println(i);
    }
}
public class Main {
    public static void main(String[] args) {
        Shared s = new Shared();
        new Thread() { public void run() { s.print(); } }.start();
        new Thread() { public void run() { s.print(); } }.start();
    }
}
